{
  "manifest_version": 3,
  "name": "Protocol Inspector → ChatGPT AutoSend",
  "version": "0.1.0",
  "description": "Opens ChatGPT, pastes a prompt from Protocol Inspector, and presses Send.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ChatGPT AutoSend"
  }
}

