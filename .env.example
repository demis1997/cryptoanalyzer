# Template only — copy to `.env` and fill in. The app reads `.env`, not this file.
#   cp .env.example .env
# Then edit `.env` with your real `CURSOR_API_KEY` (never commit `.env`).

# --- Local server ---
# PORT=3000

# --- Cursor Cloud Agents (hosted enrich) ---
ENABLE_HOSTED_ENRICH=1
LLM_PROVIDER=cursor_cloud_agents
CURSOR_API_KEY=
CURSOR_CLOUD_AGENTS_REPOSITORY=https://github.com/demis1997/cryptoanalyzer
# Optional override when API expects owner/repo only: CURSOR_CLOUD_AGENTS_REPOSITORY_SLUG=demis1997/cryptoanalyzer
# Must match a real remote branch: git ls-remote --heads https://github.com/owner/repo.git
# Persistent "branch missing" with a real branch: API key must be for a Cursor account whose GitHub has this repo + Cursor GitHub App. Check: curl -sS -u "$CURSOR_API_KEY:" https://api.cursor.com/v0/repositories
CURSOR_CLOUD_AGENTS_REF=master
# Agent model id from GET /v0/models (e.g. composer-2). Leave empty to use API default; avoid names not in that list.
CURSOR_CLOUD_AGENTS_MODEL=composer-2
# Poll until agent FINISHED (ms). Default 360000 (6m) when a step omits timeoutMs; auditors use this.
# CURSOR_CLOUD_AGENTS_TIMEOUT_MS=360000
# Longer budget for ecosystem graph + architecture steps (default 600000 = 10m).
# CURSOR_CLOUD_AGENTS_HEAVY_STEP_TIMEOUT_MS=600000

# --- Neo4j (optional graph database) ---
# ENABLE_NEO4J_GRAPH=1
# Aura / managed instances often use neo4j+s://... (routing) or bolt+s://... (direct).
# If you see "Could not perform discovery. No routing servers available", use bolt+s://.
# NEO4J_URI=neo4j+s://<your-id>.databases.neo4j.io
# NEO4J_URI=bolt+s://<your-id>.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=...
# NEO4J_DATABASE=neo4j

# --- Audit PDF ingestion (optional) ---
# Max number of audit PDFs to download+parse per analysis (default 3).
# AUDIT_PDF_MAX=3

# --- DefiLlama expansion (optional) ---
# Max number of connected protocol nodes to expand via DefiLlama protocol detail (default 6).
# DEFILLAMA_EXPAND_MAX=6

# Composer-style JSON completions (required fallback when Cloud Agents return "storage mode is disabled").
# Use your OpenAI-compatible URL from Cursor docs; same CURSOR_API_KEY usually works.
CURSOR_API_ENDPOINT=https://api.cursor.com/v1/chat/completions
CURSOR_MODEL=composer-1
PLAYWRIGHT_RENDER_TIMEOUT_MS=60000
PLAYWRIGHT_NAV_TIMEOUT_MS=60000
PLAYWRIGHT_OP_TIMEOUT_MS=60000
PLAYWRIGHT_WAIT_FOR_TEXT_TIMEOUT_MS=20000
# --- Or use composer only (no repo / Cloud Agents): LLM_PROVIDER=cursor and set CURSOR_API_ENDPOINT ---

# --- Ethereum RPC / Etherscan (connected-contract graph uses mainnet JSON-RPC) ---
# Infura: create a project at https://infura.io — put the real URL only in `.env`, never commit secrets here.
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
# ETHERSCAN_API_KEY=

# --- Performance ---
# ENABLE_WEBSITE_LLM=0
# SKIP_PLAYWRIGHT_RENDER=1

# --- PDF (Playwright) ---
# If PDF fails: npm run browsers
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
# PLAYWRIGHT_PDF_NO_SANDBOX=1

# Debug: GET http://localhost:3000/api/local-graph?limit=20
# Full pipeline (skip SQLite graph fast-path): POST /api/llm-analyze JSON body includes "forceRefresh": true
