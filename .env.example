# Copy to `.env` and fill in. `.env` is gitignored.

# --- Local server ---
# PORT=3000

# --- Hosted LLM (Cursor / OpenAI-compatible completions URL) ---
ENABLE_HOSTED_ENRICH=1
LLM_PROVIDER=cursor_cloud_agents
CURSOR_API_KEY=
# Cloud Agents requires a GitHub repo URL (Cursor clones it to run).
CURSOR_CLOUD_AGENTS_REPOSITORY=
CURSOR_CLOUD_AGENTS_REF=main
# Use "default" or an explicit model from GET /v0/models
CURSOR_CLOUD_AGENTS_MODEL=default

# --- Alternative (OpenAI-compatible completions/proxy) ---
# LLM_PROVIDER=cursor
# CURSOR_API_ENDPOINT=
# CURSOR_MODEL=composer-2
# CURSOR_API_AUTH_MODE=bearer
# CURSOR_API_BASIC_PASSWORD=

# --- Ethereum RPC (contract connection discovery) ---
# ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# --- Optional: Etherscan (wallet holdings) ---
# ETHERSCAN_API_KEY=

# --- Performance / scraping ---
# ENABLE_WEBSITE_LLM=0
# SKIP_PLAYWRIGHT_RENDER=1

# --- Optional: Cursor Cloud Agents (separate from completions; needs public GitHub repo URL) ---
# CURSOR_CLOUD_AGENTS_REPOSITORY=https://github.com/owner/repo
